# Optional first-boot overrides.
# Place on the boot partition as: gong-firstrun.env
#   (Bookworm: /boot/firmware/gong-firstrun.env
#    Buster/Bullseye: /boot/gong-firstrun.env)
#
# This file is read by firstrun.sh (and the deferred firstboot unit).

# --- Stage 0: identity ---
GONG_HOSTNAME=DhammaGong
GONG_TIMEZONE=Asia/Kolkata
GONG_KEYMAP=us

# Enable SSH on first boot (1/0)
GONG_ENABLE_SSH=1

# Ensure first user is named "pi" and set password hash (sha256crypt $5$… or leave empty to skip)
# Generate: openssl passwd -6 'YourPassword'   # or -5 for sha256crypt
# GONG_PI_PASSWORD_HASH='$5$salt$hash'
GONG_PI_PASSWORD_HASH=

# --- Wi-Fi client (optional; useful to pull packages from internet before AP mode) ---
# Leave SSID empty to skip client Wi-Fi.
GONG_CLIENT_WIFI_SSID=
GONG_CLIENT_WIFI_PSK=
GONG_WIFI_COUNTRY=IN

# --- Stage 1: Gongserver install ---
# immediate = run install.sh inside firstrun (may race network)
# deferred  = install a oneshot systemd unit that runs after network-online (recommended)
GONG_FIRSTRUN_MODE=deferred

# Where the gongserver payload lives on first boot (tried in order if empty)
# Prefer copying the full git repo onto the boot FAT partition as /boot/gongserver/
# or /boot/firmware/gongserver/
# GONG_PAYLOAD_DIR=/boot/firmware/gongserver

# Installer config (relative to payload, or absolute)
# GONG_INSTALL_CONFIG=/boot/firmware/gongserver/config.env

# Pass --with-ap to installer (1 = centre AP mode, recommended for field units)
GONG_CONFIGURE_AP=1

# Reboot after successful deferred install (1/0)
GONG_REBOOT_AFTER_INSTALL=0

# Max seconds to wait for network during deferred install
GONG_NETWORK_WAIT=180
