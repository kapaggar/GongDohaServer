# EXAMPLE only — merge the systemd.run= fragment into your real cmdline.txt.
# Keep your real root=PARTUUID=… and other stock options.
#
# Append (Buster/Bullseye boot partition):
#   systemd.run=/boot/firstrun.sh systemd.run_success_action=reboot systemd.unit=kernel-command-line.target
#
# Append (Bookworm, firmware mount):
#   systemd.run=/boot/firmware/firstrun.sh systemd.run_success_action=reboot systemd.unit=kernel-command-line.target
#
# Full example (PARTUUID will differ per card):
console=serial0,115200 console=tty1 root=PARTUUID=XXXXXXXX-02 rootfstype=ext4 fsck.repair=yes rootwait quiet cfg80211.ieee80211_regdom=IN systemd.run=/boot/firstrun.sh systemd.run_success_action=reboot systemd.unit=kernel-command-line.target
