# Copy to config.env and edit before install:
#   cp config.env.example config.env
#   sudo ./installer/install.sh
#
# Lines are sourced as shell variables.

# Hostname
GONG_HOSTNAME=DhammaGong

# Timezone
GONG_TIMEZONE=Asia/Kolkata

# MariaDB application user (installer creates DB + user)
GONG_DB_NAME=gong
GONG_DB_USER=gong
GONG_DB_PASS=ChangeThisDbPassword

# Audio player: mpg123 | mpv | omxplayer
GONG_AUDIO_PLAYER=mpg123

# Install Wi-Fi Access Point mode (hostapd + dnsmasq).
# WARNING: can disconnect SSH if you are connected via Wi-Fi.
# Prefer ethernet SSH when enabling AP.
GONG_CONFIGURE_AP=0

# AP settings (used only if GONG_CONFIGURE_AP=1)
GONG_WLAN_IFACE=wlan0
GONG_AP_ADDRESS=192.168.5.1
GONG_WIFI_SSID=DhammaGong
GONG_WIFI_PASSPHRASE=Dhamma4all
GONG_WIFI_CHANNEL=6
GONG_WIFI_COUNTRY=IN
GONG_DHCP_START=192.168.5.5
GONG_DHCP_END=192.168.5.50

# Also install phpMyAdmin (optional)
GONG_INSTALL_PHPMYADMIN=0

# Create system user 'dhamma' home for app (recommended)
GONG_APP_USER=dhamma
GONG_APP_HOME=/home/dhamma
